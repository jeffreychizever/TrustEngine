{
    "version": 2,
    "rules": [
        {
            "id": "deny-dangerous-bash",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(sudo\\b|doas\\b|pkexec\\b|su +-c\\b|rm +(-\\w+ +)*/($| )|mkfs\\b|dd +if=|chmod +-R +777 +/($| )|chown +-R +.* +/($| )|:(){ :|:& };:)"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block dangerous/destructive bash commands"
        },
        {
            "id": "deny-pipe-to-shell",
            "tool": "Bash",
            "match": {
                "command": "(curl|wget) +.*\\| *(bash|sh|zsh)"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block pipe-to-shell execution patterns"
        },
        {
            "id": "allow-read-tools",
            "tool": "Read|Glob|Grep|WebSearch|WebFetch",
            "action": "allow",
            "priority": 80,
            "description": "Allow read-only tools"
        },
        {
            "id": "allow-agent-tools",
            "tool": "Agent|TaskCreate|TaskUpdate|TaskGet|TaskList|TaskOutput|TaskStop|AskUserQuestion|EnterPlanMode|ExitPlanMode|EnterWorktree|Skill|NotebookEdit|ToolSearch|CronCreate|CronDelete|CronList",
            "action": "allow",
            "priority": 80,
            "description": "Allow agent orchestration tools"
        },
        {
            "id": "allow-write-in-safe",
            "tool": "Write|Edit",
            "match": {
                "file_path": "^$SAFE/"
            },
            "action": "allow",
            "priority": 70,
            "description": "Allow writes within safe directories"
        },
        {
            "id": "deny-pipe-to-interpreter",
            "tool": "Bash",
            "match": {
                "command": "\\| *(bash|sh|zsh|python3?|perl|ruby|node|xargs)\\b"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block piping to shell interpreters or xargs"
        },
        {
            "id": "deny-curl-mutating",
            "tool": "Bash",
            "match": {
                "command": "^curl\\b.*\\s(-X|--request|-d|--data|-F|--form|-T|--upload-file)\\b"
            },
            "action": "deny",
            "priority": 85,
            "description": "Block curl mutating/upload flags (-X, -d, -F, -T)"
        },
        {
            "id": "allow-curl-output-safe",
            "tool": "Bash",
            "match": {
                "command": "^curl\\b.*\\s(-o|--output) $SAFE/"
            },
            "action": "allow",
            "priority": 82,
            "description": "Allow curl -o targeting safe directories"
        },
        {
            "id": "deny-curl-output-unsafe",
            "tool": "Bash",
            "match": {
                "command": "^curl\\b.*\\s(-o|--output|-O|--remote-name)\\b"
            },
            "action": "deny",
            "priority": 80,
            "description": "Block curl output flags unless overridden by safe-directory grant"
        },
        {
            "id": "deny-pushd-popd",
            "tool": "Bash",
            "match": {
                "command": "^(pushd|popd)\\b"
            },
            "action": "deny",
            "priority": 75,
            "description": "Block pushd/popd — use cd instead for simpler evaluation"
        },
        {
            "id": "deny-awk-dangerous-flags",
            "tool": "Bash",
            "match": {
                "command": "^awk +.*-f\\b"
            },
            "action": "deny",
            "priority": 75,
            "description": "Block awk -f (loads script files that can call system())"
        },
        {
            "id": "deny-sed-dangerous-flags",
            "tool": "Bash",
            "match": {
                "command": "^sed +.*(-[efi]\\b|/e(\\b| ))"
            },
            "action": "deny",
            "priority": 75,
            "description": "Block sed -e/-f/-i and s///e (script execution and in-place modification)"
        },
        {
            "id": "deny-write-in-unsafe",
            "tool": "Write|Edit",
            "match": {
                "file_path": "^$UNSAFE/"
            },
            "action": "deny",
            "priority": 90,
            "description": "Block writes within unsafe directories"
        },
        {
            "id": "allow-cd",
            "tool": "Bash",
            "match": {
                "command": "^cd\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow cd (directory changes are safe; subsequent command is evaluated separately)"
        },
        {
            "id": "allow-system-info",
            "tool": "Bash",
            "match": {
                "command": "^(ls|cat|head|tail|wc|echo|printf|date|pwd|whoami|uname|which|type|file|stat|du|df|free|uptime|env|printenv|set|id|groups|hostname|basename|dirname|realpath|readlink|test|true|false|seq)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow system info and basic read-only commands"
        },
        {
            "id": "allow-text-processing",
            "tool": "Bash",
            "match": {
                "command": "^(sort|uniq|tr|cut|paste|join|comm|diff|cmp|md5sum|sha256sum|sha1sum|column|less|more|man|help|info|tree|jq|yq|awk|sed)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow text processing and viewing commands"
        },
        {
            "id": "allow-search-tools",
            "tool": "Bash",
            "match": {
                "command": "^(grep|rg|ag|ack)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow search/grep tools"
        },
        {
            "id": "allow-git-readonly",
            "tool": "Bash",
            "match": {
                "command": "^git +(status|log|diff|show|branch|tag|remote|fetch|stash|ls-files|rev-parse|describe|config +--get|config +--list|blame|shortlog|reflog|init)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow read-only git commands"
        },
        {
            "id": "allow-node-ecosystem",
            "tool": "Bash",
            "match": {
                "command": "^(npm +(test|run|ls|list|outdated|audit|info|view|explain|why|pack +--dry-run)|npx|node +(--version|-v)|yarn +(test|run|list|info|why)|pnpm +(test|run|list|ls|why)|bun +(test|run))\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow Node.js ecosystem read-only and test commands"
        },
        {
            "id": "allow-rust-go-python",
            "tool": "Bash",
            "match": {
                "command": "^(cargo +(test|check|clippy|build|bench|doc|fmt)|rustc +--version|go +(test|vet|build|run|fmt|doc)|python3? +-m +(pytest|unittest|json\\.tool|py_compile|compileall)|pip3? +(list|show|freeze))\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow Rust, Go, and Python build/test commands"
        },
        {
            "id": "allow-ruby-java",
            "tool": "Bash",
            "match": {
                "command": "^(ruby +-c|bundle +(exec|list|show|info)|rake |rspec|java +--version|javac +--version|mvn +(test|verify|compile|package)|gradle +(test|check|build))\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow Ruby and Java build/test commands"
        },
        {
            "id": "allow-build-tools",
            "tool": "Bash",
            "match": {
                "command": "^(gcc +--version|g\\+\\+ +--version|clang +--version)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow C/C++ compiler version checks"
        },
        {
            "id": "allow-containers-infra",
            "tool": "Bash",
            "match": {
                "command": "^(docker +(ps|images|logs|inspect|version)|kubectl +(get|describe|logs|version)|terraform +(plan|validate|fmt))\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow read-only container and infrastructure commands"
        },
        {
            "id": "allow-linters",
            "tool": "Bash",
            "match": {
                "command": "^(tsc|eslint_d|flake8|rubocop|cpplint|shellcheck|luacheck|checkstyle|prettier|black|isort|gofmt|rustfmt)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow linters and formatters"
        },
        {
            "id": "allow-mkdir-touch-safe",
            "tool": "Bash",
            "match": {
                "command": "^(mkdir|touch)\\b.* $SAFE/"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow mkdir/touch in safe directories"
        },
        {
            "id": "allow-cp-mv-safe",
            "tool": "Bash",
            "match": {
                "command": "^(cp|mv)\\b.* $SAFE/"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow cp/mv targeting safe directories"
        },
        {
            "id": "allow-git-commit",
            "tool": "Bash",
            "match": {
                "command": "^git +(add|commit|checkout|switch|merge|cherry-pick|stash +(pop|apply|drop))\\b"
            },
            "action": "allow",
            "priority": 55,
            "description": "Allow local git mutation commands"
        }
    ],
    "known_risks": [
        {
            "id": "risk-git-push",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)git +push\\b"
            },
            "risk": "git push modifies shared remote state — others may pull these changes",
            "severity": "escalate"
        },
        {
            "id": "risk-git-destructive",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)git +(reset +--hard|rebase|push +--force|push +-f)\\b"
            },
            "risk": "Destructive git history rewrite — can lose commits and affect collaborators",
            "severity": "escalate"
        },
        {
            "id": "risk-network",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(curl|wget)\\b"
            },
            "risk": "Network request — may exfiltrate data or download untrusted content",
            "severity": "escalate"
        },
        {
            "id": "risk-rm",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)rm\\b"
            },
            "risk": "File deletion is irreversible — verify targets carefully",
            "severity": "escalate"
        },
        {
            "id": "risk-env-secrets",
            "tool": "Write|Edit",
            "match": {
                "file_path": "\\.env"
            },
            "risk": ".env files may contain secrets — edits could expose credentials",
            "severity": "escalate"
        },
        {
            "id": "risk-npm-publish",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)npm +publish\\b"
            },
            "risk": "npm publish pushes packages to public registry — this is irreversible",
            "severity": "block"
        },
        {
            "id": "risk-metachar-injection",
            "tool": "Bash",
            "match": {
                "command": "\\$\\(|`[^`]*`|\\$\\{"
            },
            "risk": "Command contains shell substitution ($(), backticks, ${}) — verify the expanded command is safe",
            "severity": "escalate"
        },
        {
            "id": "risk-redirect",
            "tool": "Bash",
            "match": {
                "command": "[^2]>(?!/dev/null)"
            },
            "risk": "Output redirect may overwrite files — verify the target path",
            "severity": "acknowledge"
        },
        {
            "id": "risk-post-install-scripts",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(npm +(install|ci|i)\\b|make\\b|cmake\\b)"
            },
            "risk": "Build/install commands can execute arbitrary post-install scripts",
            "severity": "escalate"
        },
        {
            "id": "risk-file-overwrite",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(cp|mv|ln)\\b"
            },
            "risk": "cp/mv/ln can overwrite files or create misleading symlinks — verify targets carefully",
            "severity": "acknowledge"
        }
    ]
}
