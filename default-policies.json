{
    "version": 1,
    "rules": [
        {
            "id": "deny-dangerous-bash",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(sudo\\b|doas\\b|pkexec\\b|su +-c\\b|rm +(-\\w+ +)*/($| )|mkfs\\b|dd +if=|chmod +-R +777 +/($| )|chown +-R +.* +/($| )|:(){ :|:& };:)"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block dangerous/destructive bash commands"
        },
        {
            "id": "deny-pipe-to-shell",
            "tool": "Bash",
            "match": {
                "command": "(curl|wget) +.*\\| *(bash|sh|zsh)"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block pipe-to-shell execution patterns"
        },
        {
            "id": "deny-write-outside-cwd",
            "tool": "Write|Edit",
            "match": {
                "file_path": "^(?!$CWD)"
            },
            "action": "deny",
            "priority": 81,
            "description": "Block writes outside the current working directory"
        },
        {
            "id": "allow-read-tools",
            "tool": "Read|Glob|Grep|WebSearch|WebFetch",
            "action": "allow",
            "priority": 80,
            "description": "Allow read-only tools"
        },
        {
            "id": "allow-agent-tools",
            "tool": "Agent|TaskCreate|TaskUpdate|TaskGet|TaskList|TaskOutput|TaskStop|AskUserQuestion|EnterPlanMode|ExitPlanMode|EnterWorktree|Skill|NotebookEdit|ToolSearch|CronCreate|CronDelete|CronList",
            "action": "allow",
            "priority": 80,
            "description": "Allow agent orchestration tools"
        },
        {
            "id": "allow-write-in-cwd",
            "tool": "Write|Edit",
            "match": {
                "file_path": "^$CWD/"
            },
            "action": "allow",
            "priority": 70,
            "description": "Allow writes within the current working directory"
        },
        {
            "id": "allow-safe-bash",
            "tool": "Bash",
            "match": {
                "command": "^(ls|cat|head|tail|wc|echo|printf|date|pwd|whoami|uname|which|type|file|stat|du|df|free|uptime|env|printenv|set|id|groups|hostname|basename|dirname|realpath|readlink|test|true|false|seq|sort|uniq|tr|cut|paste|join|comm|diff|cmp|md5sum|sha256sum|sha1sum|grep|rg|ag|ack|jq|yq|column|less|more|man|help|info|tree|git +(status|log|diff|show|branch|tag|remote|fetch|stash|ls-files|rev-parse|describe|config +--get|config +--list|blame|shortlog|reflog|init)|npm +(test|run|ls|list|outdated|audit|info|view|explain|why|pack +--dry-run)|npx|node +(--version|-v)|yarn +(test|run|list|info|why)|pnpm +(test|run|list|ls|why)|bun +(test|run)|cargo +(test|check|clippy|build|bench|doc|fmt)|rustc +--version|go +(test|vet|build|run|fmt|doc)|python3? +-m +(pytest|unittest|json\\.tool|py_compile|compileall)|pip +(list|show|freeze)|pip3 +(list|show|freeze)|ruby +-c|bundle +(exec|list|show|info)|rake +|rspec|java +--version|javac +--version|mvn +(test|verify|compile|package)|gradle +(test|check|build)|make |cmake |gcc +--version|g\\+\\+ +--version|clang +--version|docker +(ps|images|logs|inspect|version)|kubectl +(get|describe|logs|version)|terraform +(plan|validate|fmt)|tsc|eslint_d|flake8|rubocop|cpplint|shellcheck|luacheck|checkstyle|prettier|black|isort|gofmt|rustfmt|mkdir|touch|cp|mv|ln)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow common safe bash commands"
        },
        {
            "id": "allow-npm-install",
            "tool": "Bash",
            "match": {
                "command": "^npm +(install|ci|i)\\b"
            },
            "action": "allow",
            "priority": 55,
            "description": "Allow npm install commands"
        },
        {
            "id": "allow-git-commit",
            "tool": "Bash",
            "match": {
                "command": "^git +(add|commit|checkout|switch|merge|rebase|cherry-pick|reset +--soft|stash +(pop|apply|drop))\\b"
            },
            "action": "allow",
            "priority": 55,
            "description": "Allow local git mutation commands"
        }
    ],
    "known_risks": [
        {
            "id": "risk-git-push",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)git +push\\b"
            },
            "risk": "git push modifies shared remote state — others may pull these changes",
            "severity": "escalate"
        },
        {
            "id": "risk-git-destructive",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)git +(reset +--hard|rebase|push +--force|push +-f)\\b"
            },
            "risk": "Destructive git history rewrite — can lose commits and affect collaborators",
            "severity": "escalate"
        },
        {
            "id": "risk-network",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(curl|wget)\\b"
            },
            "risk": "Network request — may exfiltrate data or download untrusted content",
            "severity": "escalate"
        },
        {
            "id": "risk-rm",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)rm\\b"
            },
            "risk": "File deletion is irreversible — verify targets carefully",
            "severity": "escalate"
        },
        {
            "id": "risk-env-secrets",
            "tool": "Write|Edit",
            "match": {
                "file_path": "\\.env"
            },
            "risk": ".env files may contain secrets — edits could expose credentials",
            "severity": "escalate"
        },
        {
            "id": "risk-npm-publish",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)npm +publish\\b"
            },
            "risk": "npm publish pushes packages to public registry — this is irreversible",
            "severity": "block"
        },
        {
            "id": "risk-file-overwrite",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|] *)(cp|mv|ln)\\b"
            },
            "risk": "cp/mv/ln can overwrite files or create misleading symlinks — verify targets carefully",
            "severity": "acknowledge"
        }
    ]
}
