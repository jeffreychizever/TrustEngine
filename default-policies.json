{
    "version": 1,
    "rules": [
        {
            "id": "deny-dangerous-bash",
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)(sudo\\b|doas\\b|pkexec\\b|su\\s+-c\\b|rm\\s+(-\\w+\\s+)*/($|\\s)|mkfs\\b|dd\\s+if=|chmod\\s+-R\\s+777\\s+/($|\\s)|chown\\s+-R\\s+.*\\s+/($|\\s)|:(){ :|:& };:)"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block dangerous/destructive bash commands"
        },
        {
            "id": "deny-pipe-to-shell",
            "tool": "Bash",
            "match": {
                "command": "(curl|wget)\\s+.*\\|\\s*(bash|sh|zsh)"
            },
            "action": "deny",
            "priority": 100,
            "description": "Block pipe-to-shell execution patterns"
        },
        {
            "id": "deny-write-outside-cwd",
            "tool": "Write|Edit",
            "match": {
                "file_path": "^(?!$CWD)"
            },
            "action": "deny",
            "priority": 90,
            "description": "Block writes outside the current working directory"
        },
        {
            "id": "allow-read-tools",
            "tool": "Read|Glob|Grep|WebSearch|WebFetch",
            "action": "allow",
            "priority": 80,
            "description": "Allow read-only tools"
        },
        {
            "id": "allow-agent-tools",
            "tool": "Agent|TaskCreate|TaskUpdate|TaskGet|TaskList|AskUserQuestion|EnterPlanMode|ExitPlanMode|Skill|NotebookEdit",
            "action": "allow",
            "priority": 80,
            "description": "Allow agent orchestration tools"
        },
        {
            "id": "allow-write-in-cwd",
            "tool": "Write|Edit",
            "match": {
                "file_path": "^$CWD/"
            },
            "action": "allow",
            "priority": 70,
            "description": "Allow writes within the current working directory"
        },
        {
            "id": "allow-safe-bash",
            "tool": "Bash",
            "match": {
                "command": "^(ls|cat|head|tail|wc|echo|printf|date|pwd|whoami|uname|which|type|file|stat|du|df|free|uptime|env|printenv|set|id|groups|hostname|basename|dirname|realpath|readlink|test|true|false|seq|sort|uniq|tr|cut|paste|join|comm|diff|cmp|md5sum|sha256sum|sha1sum|grep|rg|ag|ack|jq|yq|column|less|more|man|help|info|tree|git\\s+(status|log|diff|show|branch|tag|remote|fetch|stash|ls-files|rev-parse|describe|config\\s+--get|config\\s+--list|blame|shortlog|reflog)|npm\\s+(test|run|ls|list|outdated|audit|info|view|explain|why|pack\\s+--dry-run)|npx|node\\s+(--version|-v)|yarn\\s+(test|run|list|info|why)|pnpm\\s+(test|run|list|ls|why)|bun\\s+(test|run)|cargo\\s+(test|check|clippy|build|bench|doc|fmt)|rustc\\s+--version|go\\s+(test|vet|build|run|fmt|doc)|python3?\\s+-m\\s+(pytest|unittest|json\\.tool|py_compile|compileall)|pip\\s+(list|show|freeze)|pip3\\s+(list|show|freeze)|ruby\\s+-c|bundle\\s+(exec|list|show|info)|rake\\s+|rspec|java\\s+--version|javac\\s+--version|mvn\\s+(test|verify|compile|package)|gradle\\s+(test|check|build)|make\\s|cmake\\s|gcc\\s+--version|g\\+\\+\\s+--version|clang\\s+--version|docker\\s+(ps|images|logs|inspect|version)|kubectl\\s+(get|describe|logs|version)|terraform\\s+(plan|validate|fmt)|tsc|eslint_d|flake8|rubocop|cpplint|shellcheck|luacheck|checkstyle|prettier|black|isort|gofmt|rustfmt|mkdir|touch|cp|mv|ln)\\b"
            },
            "action": "allow",
            "priority": 60,
            "description": "Allow common safe bash commands"
        },
        {
            "id": "allow-npm-install",
            "tool": "Bash",
            "match": {
                "command": "^npm\\s+(install|ci|i)\\b"
            },
            "action": "allow",
            "priority": 55,
            "description": "Allow npm install commands"
        },
        {
            "id": "allow-git-commit",
            "tool": "Bash",
            "match": {
                "command": "^git\\s+(add|commit|checkout|switch|merge|rebase|cherry-pick|reset\\s+--soft|stash\\s+(pop|apply|drop))\\b"
            },
            "action": "allow",
            "priority": 55,
            "description": "Allow local git mutation commands"
        }
    ],
    "known_risks": [
        {
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)git\\s+push\\b"
            },
            "risk": "git push modifies shared remote state — others may pull these changes",
            "severity": "medium"
        },
        {
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)git\\s+(reset\\s+--hard|rebase|push\\s+--force|push\\s+-f)\\b"
            },
            "risk": "Destructive git history rewrite — can lose commits and affect collaborators",
            "severity": "high"
        },
        {
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)(curl|wget)\\b"
            },
            "risk": "Network request — may exfiltrate data or download untrusted content",
            "severity": "medium"
        },
        {
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)rm\\b"
            },
            "risk": "File deletion is irreversible — verify targets carefully",
            "severity": "medium"
        },
        {
            "tool": "Write|Edit",
            "match": {
                "file_path": "\\.env"
            },
            "risk": ".env files may contain secrets — edits could expose credentials",
            "severity": "high"
        },
        {
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)npm\\s+publish\\b"
            },
            "risk": "npm publish pushes packages to public registry — this is irreversible",
            "severity": "high"
        },
        {
            "tool": "Bash",
            "match": {
                "command": "(^|[;&|]\\s*)(cp|mv|ln)\\b"
            },
            "risk": "cp/mv/ln can overwrite files or create misleading symlinks — verify targets carefully",
            "severity": "medium"
        }
    ]
}
